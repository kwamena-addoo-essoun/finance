# ============================================================
# Finsight — Environment Variables Template
# Copy this file to .env and fill in all values.
# NEVER commit .env to git — it is in .gitignore.
# ============================================================

# --- Database ---
# Local dev (SQLite — auto-created, no setup needed):
DATABASE_URL=sqlite:///./finance_app.db
# Production (PostgreSQL — used by docker-compose automatically):
# DATABASE_URL=postgresql://finance_user:finance_pass@db:5432/finance_db

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_GENERATED_KEY

# Cookie settings (set to your domain in production)
COOKIE_DOMAIN=
COOKIE_SECURE=false

# --- OpenAI (AI expense categorisation) ---
# Get from https://platform.openai.com/api-keys
# Without this, expenses default to category "Other"
OPENAI_API_KEY=

# --- Email (Resend) ---
# Sign up free at https://resend.com
# Must verify your sending domain before emails reach real users.
# During development you can use onboarding@resend.dev (only delivers to your own address).
RESEND_API_KEY=
FROM_EMAIL=Finsight <noreply@yourdomain.com>
FRONTEND_URL=http://localhost:3000

# --- Plaid (Bank Linking) ---
# Sign up free at https://dashboard.plaid.com
# sandbox     = fake banks, free, unlimited testing
# development = real banks, free up to 100 users
# production  = real banks, paid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# Production example: ALLOWED_ORIGINS=https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- PostgreSQL (used by docker-compose only) ---
POSTGRES_USER=finance_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=finance_db

# --- Deployment ---
DOMAIN=yourdomain.com

# --- Sentry (Error Monitoring) ---
# Sign up free at https://sentry.io — create a Python/FastAPI project
SENTRY_DSN=

